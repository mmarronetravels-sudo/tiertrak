# Frontend environment variables.
#
# Vite loads these in this order (highest priority wins):
#   .env.development.local  (gitignored, per-dev dev override)
#   .env.development        (committed, dev default — sets
#                            localhost API)
#   .env.local              (gitignored, per-dev override
#                            that applies to ALL modes)
#   .env                    (gitignored)
#
# Production builds (vite build) use .env.production and/or
# Vercel dashboard env vars; .env.development is NOT loaded
# in prod.

# API base URL the frontend talks to.
# Dev default (localhost) is set in .env.development.
# For staging or remote-dev experiments, copy to
# .env.development.local and override.
VITE_API_URL=

# Google OAuth client ID (required for Google SSO login).
# Per-machine: copy to .env.development.local and fill in.
VITE_GOOGLE_CLIENT_ID=
